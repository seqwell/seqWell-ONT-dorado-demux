{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "allOf": [
        {
            "$ref": "#/$defs/input_output_options"
        },
        {
            "$ref": "#/$defs/demux_options"
        }
    ],
    "title": "seqWell ONT Dorado Demux",
    "$defs": {
        "input_output_options": {
            "title": "Input & Output Options",
            "description": "Define the input and output data locations.",
            "fa_icon": "fas fa-terminal",
            "properties": {
                "input": {
                    "description": "Path to directory containing input files (*.bam or *.fastq.gz). Supports local paths and AWS S3 URIs.",
                    "fa_icon": "fas fa-folder",
                    "format": "directory-path",
                    "type": "string"
                },
                "outdir": {
                    "description": "Output directory. Supports local paths and AWS S3 URIs.",
                    "fa_icon": "fas fa-folder-open",
                    "format": "directory-path",
                    "type": "string"
                },
                "pool_ID": {
                    "description": "Unique identifier for the sequencing run. Used in the demux summary report filename.",
                    "type": "string"
                }
            },
            "required": [
                "input",
                "outdir",
                "pool_ID"
            ],
            "type": "object"
        },
        "demux_options": {
            "title": "Demultiplexing Options",
            "description": "Options for demultiplexing configuration.",
            "fa_icon": "fas fa-sliders-h",
            "properties": {
                "data_type": {
                    "description": "Input file format. Must be 'bam' or 'fastq'. BAM input produces FASTQ and filtered BAM outputs; FASTQ input produces FASTQ outputs only.",
                    "fa_icon": "fas fa-file-code",
                    "type": "string",
                    "enum": [
                        "bam",
                        "fastq"
                    ]
                },
                "barcodes": {
                    "description": "Path to the barcode FASTA file.",
                    "default": "assets/barcodes.384.fa",
                    "fa_icon": "fas fa-file",
                    "format": "file-path",
                    "type": "string"
                },
                "arrangement_toml": {
                    "description": "Path to the barcode arrangement TOML configuration file for Dorado.",
                    "default": "assets/arrangement.toml",
                    "fa_icon": "fas fa-file-alt",
                    "format": "file-path",
                    "type": "string"
                },
                "length_filter": {
                    "description": "Minimum read length (bp) to retain after trimming.",
                    "default": 150,
                    "type": "integer",
                    "minimum": 50
                },
                "error_rate": {
                    "description": "Error rate threshold used by CUTADAPT_TRIM to filter reads with residual ME adapter sequence.",
                    "default": 0.12,
                    "type": "number",
                    "minimum": 0,
                    "maximum": 1
                }
            },
            "required": [
                "data_type"
            ],
            "type": "object"
        }
    },
    "type": "object"
}
